# Public app version shown in Settings (safe to expose).
# In Vercel, set this per deploy/tag (example: 1.0.0 or 2026.02.25).
VITE_APP_VERSION=1.0.0

# Optional runtime error collector endpoint.
# Leave empty to keep monitoring local-only (no network reporting).
# Recommended for Vercel (same-origin endpoint, CSP-safe):
# VITE_ERROR_REPORT_ENDPOINT=/api/runtime-errors
# For external endpoints, also add that domain to vercel.json CSP connect-src.
VITE_ERROR_REPORT_ENDPOINT=

# Account sync + login (required in Vercel production for cross-device save)
# Vercel KV / Upstash REST credentials:
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
#
# Session signing secret (long random string):
# AUTH_SESSION_SECRET=change-this-to-a-long-random-secret
#
# Optional canonical app origin used in password reset links:
# PUBLIC_APP_ORIGIN=https://your-app.example.com
#
# Signup email verification (recommended for production):
# RESEND_API_KEY=re_xxx
# ACCOUNT_EMAIL_FROM=Pocket Ledger <no-reply@yourdomain.com>
# Optional separate secret for verification code hashing:
# AUTH_VERIFICATION_SECRET=another-long-random-secret
